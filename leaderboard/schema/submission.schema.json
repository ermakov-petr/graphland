{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ermakov-petr.github.io/graphland/schema/submission.schema.json",
  "title": "GraphLand leaderboard submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "model_name",
    "model_variant",
    "paper_url",
    "code_availability",
    "training_code_url",
    "submitter_github",
    "provenance",
    "source_issue",
    "graphland_ref",
    "method_type",
    "hparam_trials",
    "tuning_protocol",
    "num_runs",
    "external_data_pretraining",
    "submitted_at",
    "verification",
    "review",
    "notes",
    "results"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "id": {
      "type": "string",
      "pattern": "^(?:issue-[1-9][0-9]*|[a-z0-9]+(?:-[a-z0-9]+)*)$",
      "maxLength": 100
    },
    "model_name": {"type": "string", "minLength": 1, "maxLength": 120},
    "model_variant": {"type": "string", "minLength": 1, "maxLength": 120},
    "paper_url": {"type": "string", "format": "uri", "maxLength": 500},
    "code_availability": {"enum": ["available", "unavailable"]},
    "training_code_url": {
      "oneOf": [
        {"type": "string", "format": "uri", "maxLength": 500},
        {"type": "null"}
      ]
    },
    "submitter_github": {
      "type": "string",
      "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$",
      "maxLength": 39
    },
    "provenance": {"enum": ["author_submission", "maintainer_seeded"]},
    "source_issue": {"type": "integer", "minimum": 1},
    "graphland_ref": {"type": "string", "minLength": 1, "maxLength": 100},
    "method_type": {"enum": ["trained", "in_context"]},
    "hparam_trials": {"type": "integer", "minimum": 0, "maximum": 1000000},
    "tuning_protocol": {"type": "string", "minLength": 1, "maxLength": 4000},
    "num_runs": {"type": "integer", "minimum": 1, "maximum": 1000000},
    "external_data_pretraining": {"type": "string", "minLength": 1, "maxLength": 4000},
    "submitted_at": {"type": "string", "format": "date"},
    "verification": {"enum": ["self_reported", "reproduced"]},
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewer_github", "reviewed_at", "notes"],
      "properties": {
        "status": {"enum": ["pending", "approved"]},
        "reviewer_github": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[A-Za-z0-9](?:[A-Za-z0-9-]{0,37}[A-Za-z0-9])?$",
              "maxLength": 39
            },
            {"type": "null"}
          ]
        },
        "reviewed_at": {
          "oneOf": [
            {"type": "string", "format": "date"},
            {"type": "null"}
          ]
        },
        "notes": {
          "oneOf": [
            {"type": "string", "maxLength": 2000},
            {"type": "null"}
          ]
        }
      }
    },
    "notes": {
      "oneOf": [
        {"type": "string", "maxLength": 4000},
        {"type": "null"}
      ]
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 48,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["setting", "dataset", "value"],
        "properties": {
          "setting": {"enum": ["RL", "RH", "TH", "THI"]},
          "dataset": {"type": "string", "minLength": 1, "maxLength": 100},
          "value": {"type": "number"},
          "std": {"type": "number", "minimum": 0}
        }
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"method_type": {"const": "in_context"}}},
      "then": {"properties": {"hparam_trials": {"const": 0}}}
    },
    {
      "if": {"properties": {"code_availability": {"const": "available"}}},
      "then": {"properties": {"training_code_url": {"type": "string"}}},
      "else": {"properties": {"training_code_url": {"type": "null"}}}
    }
  ]
}
